# Career Discovery Platform - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

################################################################################
# FIREBASE CONFIGURATION
# Get these values from Firebase Console
# https://console.firebase.google.com
################################################################################

REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
REACT_APP_FIREBASE_PROJECT_ID=your_firebase_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id_here
REACT_APP_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

################################################################################
# APPLICATION CONFIGURATION
################################################################################

# Frontend Port (for development server)
PORT=8000
HOST=127.0.0.1

# API Endpoint (for gesture recognition server)
REACT_APP_API_URL=http://localhost:5000
REACT_APP_GESTURE_API=http://localhost:5000/predict

# Environment
NODE_ENV=development
APP_ENV=development

################################################################################
# PYTHON/FLASK CONFIGURATION (ML Server)
################################################################################

# Flask Settings
FLASK_ENV=development
FLASK_APP=gesture_server.py
FLASK_DEBUG=1

# Gesture Recognition Model
MODEL_PATH=./gesture_model.h5
CONFIDENCE_THRESHOLD=0.7

# Webcam settings
WEBCAM_WIDTH=1280
WEBCAM_HEIGHT=720
WEBCAM_FPS=30

################################################################################
# DATABASE CONFIGURATION
################################################################################

# Firestore (managed by Firebase)
# No separate DB credentials needed - Firebase handles this

################################################################################
# LOGGING & DEBUG
################################################################################

# Logging Level
LOG_LEVEL=info
DEBUG=false

# Enable detailed console output
VERBOSE_LOGGING=false

################################################################################
# ANALYTICS & TRACKING
################################################################################

# Google Analytics (optional)
REACT_APP_GA_ID=your_ga_id_here

# Sentry Error Tracking (optional)
REACT_APP_SENTRY_DSN=

################################################################################
# FEATURE FLAGS
################################################################################

# Enable/disable features
REACT_APP_ENABLE_GESTURES=true
REACT_APP_ENABLE_VOICE=true
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_OFFLINE_MODE=false

################################################################################
# SECURITY
################################################################################

# CORS Settings
CORS_ORIGIN=http://localhost:8000

# Session timeout (in minutes)
SESSION_TIMEOUT=30

################################################################################
# INSTRUCTIONS FOR SETUP
################################################################################

# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your Firebase credentials from Firebase Console
#
# 3. Update other settings as needed
#
# 4. Add .env to .gitignore (should be automatic)
#
# 5. Start your servers:
#    npm start
#    python src/ml/gesture_server.py
#
# ⚠️  NEVER share your .env file or commit it to Git!
# ⚠️  Keep your Firebase credentials secret!
